
generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

enum ClientRole {
  ADMIN
  CLIENT
  VIEWER
}

enum JobStatus {
  PENDING
  PROCESSING
  COMPLETED
  FAILED
}

enum PeriodStatus {
  ACTIVE
  CLOSED
}

enum TipoGasto {
  ORDINARIO
  EXTRAORDINARIO
  PARTICULAR
}

enum PaymentMethod {
  DEBITO_AUTOMATICO
  TRANSFERENCIA
  EFECTIVO
}

model Client {
  id                   String           @id @default(cuid())
  name                 String
  email                String           @unique
  passwordHash         String
  role                 ClientRole       @default(CLIENT)
  isActive             Boolean          @default(true)
  consortiumsEnabled   Boolean          @default(false)
  batchSize            Int              @default(10)
  intervalMinutes      Int              @default(60)
  driveFoldersJson     Json?
  googleConfigJson     Json?
  extractionConfigJson Json?
  createdAt            DateTime         @default(now())
  updatedAt            DateTime         @updatedAt
  consortiums          Consortium[]
  invoices             Invoice[]
  periods              Period[]
  providers            Provider[]
  receipts             Receipt[]
  coeficientes         Coeficiente[]
  rubros               Rubro[]
  lspServices          LspService[]
  processingLogs       ProcessingLog[]
  processingJobs       ProcessingJob[]
  schedulerStates      SchedulerState[]
  tokenUsages          TokenUsage[]

  @@index([isActive])
  @@index([role, isActive])
}

model ProcessingJob {
  id            String    @id @default(cuid())
  clientId      String
  driveFileId   String
  driveFileName String?
  status        JobStatus @default(PENDING)
  attempts      Int       @default(0)
  maxAttempts   Int       @default(3)
  errorMessage  String?
  createdAt     DateTime  @default(now())
  startedAt     DateTime?
  finishedAt    DateTime?
  client        Client    @relation(fields: [clientId], references: [id])

  @@index([clientId])
  @@index([status])
}

model Invoice {
  id                  String       @id @default(cuid())
  clientId            String
  consortiumId        String?
  documentHash        String
  boletaNumber        String?
  provider            String?
  consortium          String?
  providerId          String?
  providerTaxId       String?
  detail              String?
  observation         String?
  issueDate           DateTime?
  dueDate             DateTime?
  periodId            String?
  amount              Decimal?     @db.Decimal(14, 2)
  alias               String?
  coeficienteId       String?
  rubroId             String?
  tipoGasto           TipoGasto    @default(ORDINARIO)
  tipoComprobante     String?
  lspServiceId        String?
  paymentMethod       PaymentMethod?
  driveFileId         String?
  sourceFileUrl       String?
  isDuplicate         Boolean      @default(false)
  isManual            Boolean      @default(false)
  tokensInput         Int?
  tokensOutput        Int?
  tokensTotal         Int?
  aiProvider          String?
  aiModel             String?
  boletaNumberNorm    String       @default("")
  providerTaxIdNorm   String       @default("")
  dueDateNorm         String       @default("")
  amountNorm          String       @default("")
  receiptDriveFileId  String?
  receiptDriveFileUrl String?
  createdAt           DateTime     @default(now())
  updatedAt           DateTime     @updatedAt
  client              Client       @relation(fields: [clientId], references: [id], onDelete: Cascade)
  consortiumRef       Consortium?  @relation(fields: [consortiumId], references: [id], onDelete: SetNull)
  providerRef         Provider?    @relation(fields: [providerId], references: [id], onDelete: SetNull)
  periodRef           Period?      @relation(fields: [periodId], references: [id], onDelete: SetNull)
  coeficienteRef      Coeficiente? @relation(fields: [coeficienteId], references: [id], onDelete: SetNull)
  rubroRef            Rubro?       @relation(fields: [rubroId], references: [id], onDelete: SetNull)
  lspServiceRef       LspService?  @relation(fields: [lspServiceId], references: [id], onDelete: SetNull)
  receipt             Receipt?     @relation("InvoiceReceipt")

  @@unique([clientId, documentHash], map: "uq_invoice_document_hash")
  @@unique([clientId, boletaNumberNorm, providerTaxIdNorm, dueDateNorm, amountNorm], map: "uq_invoice_business_key")
  @@index([clientId, createdAt])
  @@index([consortiumId, periodId])
}

model Coeficiente {
  id          String    @id @default(cuid())
  clientId    String
  code        String
  name        String
  value       Decimal?  @db.Decimal(10, 6)
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
  client      Client    @relation(fields: [clientId], references: [id], onDelete: Cascade)
  invoices    Invoice[]

  @@unique([clientId, code])
  @@index([clientId])
}

model Rubro {
  id          String    @id @default(cuid())
  clientId    String
  name        String
  description String?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
  client      Client    @relation(fields: [clientId], references: [id], onDelete: Cascade)
  invoices    Invoice[]

  @@unique([clientId, name])
  @@index([clientId])
}

model Receipt {
  id            String     @id @default(cuid())
  clientId      String
  consortiumId  String
  providerId    String
  periodId      String
  invoiceId     String?    @unique
  driveFileId   String
  driveFileName String?
  driveFileUrl  String?
  amount        Decimal?   @db.Decimal(14, 2)
  paymentDate   DateTime?
  observation   String?
  createdAt     DateTime   @default(now())
  updatedAt     DateTime   @updatedAt
  client        Client     @relation(fields: [clientId], references: [id], onDelete: Cascade)
  consortium    Consortium @relation(fields: [consortiumId], references: [id], onDelete: Cascade)
  provider      Provider   @relation(fields: [providerId], references: [id], onDelete: Cascade)
  period        Period     @relation(fields: [periodId], references: [id], onDelete: Cascade)
  invoice       Invoice?   @relation("InvoiceReceipt", fields: [invoiceId], references: [id], onDelete: SetNull)

  @@index([clientId])
  @@index([consortiumId, periodId])
  @@index([providerId])
  @@index([invoiceId])
}

model ProcessingLog {
  id           String    @id @default(cuid())
  clientId     String
  trigger      String
  status       String
  startedAt    DateTime
  endedAt      DateTime?
  durationMs   Int?
  summaryJson  Json?
  errorMessage String?
  createdAt    DateTime  @default(now())
  client       Client    @relation(fields: [clientId], references: [id], onDelete: Cascade)

  @@index([clientId, startedAt])
}

model SchedulerState {
  id                String    @id @default(cuid())
  clientId          String
  enabled           Boolean   @default(true)
  isRunning         Boolean   @default(false)
  intervalMinutes   Int       @default(5)
  lastTrigger       String?
  lastRunStartedAt  DateTime?
  lastRunEndedAt    DateTime?
  lastHeartbeatAt   DateTime?
  lastError         String?
  lastSummaryJson   Json?
  totalRuns         Int       @default(0)
  totalFound        Int       @default(0)
  totalProcessed    Int       @default(0)
  totalSkipped      Int       @default(0)
  totalFailed       Int       @default(0)
  totalDuplicates   Int       @default(0)
  totalInputTokens  Int       @default(0)
  totalOutputTokens Int       @default(0)
  totalTokens       Int       @default(0)
  quotaOpenAiStatus String    @default("unknown")
  quotaOpenAiNote   String?
  quotaGeminiStatus    String    @default("unknown")
  quotaGeminiNote      String?
  lastDirectorySyncAt  DateTime?
  createdAt            DateTime  @default(now())
  updatedAt         DateTime  @updatedAt
  client            Client    @relation(fields: [clientId], references: [id], onDelete: Cascade)

  @@unique([clientId])
}

model TokenUsage {
  id           String   @id @default(cuid())
  clientId     String
  provider     String
  model        String?
  inputTokens  Int      @default(0)
  outputTokens Int      @default(0)
  totalTokens  Int      @default(0)
  runAt        DateTime @default(now())
  metaJson     Json?
  createdAt    DateTime @default(now())
  client       Client   @relation(fields: [clientId], references: [id], onDelete: Cascade)

  @@index([clientId, runAt])
  @@index([provider])
}

model Consortium {
  id                     String               @id @default(cuid())
  clientId               String
  canonicalName          String
  rawName                String
  cuit                   String?
  cutoffDay              Int                  @default(5)
  driveFolderProcessedId String?
  /// Nombres alternativos separados por | para matching interno con facturas de servicios.
  /// Ej: "BROWN ALMTE AV 708|ALMTE BROWN 706" permite que Edesur encuentre
  /// el consorcio aunque use una dirección distinta a la canónica.
  /// Campo interno — no se muestra en la UI.
  matchNames             String?
  /// Alias visible en la UI y en la columna "ALIAS" de Google Sheets.
  paymentAlias           String?
  createdAt              DateTime             @default(now())
  updatedAt              DateTime             @updatedAt
  client                 Client               @relation(fields: [clientId], references: [id], onDelete: Cascade)
  periods                Period[]
  consortiumProviders    ConsortiumProvider[]
  invoices               Invoice[]
  receipts               Receipt[]
  lspServices            LspService[]

  @@unique([clientId, canonicalName])
  @@index([clientId])
}

model Provider {
  id                  String               @id @default(cuid())
  clientId            String
  canonicalName       String
  cuit                String?
  /// Nombres alternativos separados por | para matching interno.
  /// Campo interno — no se muestra en la UI.
  matchNames          String?
  /// Alias visible en la UI y en la columna "ALIAS" de Google Sheets.
  paymentAlias        String?
  createdAt           DateTime             @default(now())
  updatedAt           DateTime             @updatedAt
  client              Client               @relation(fields: [clientId], references: [id], onDelete: Cascade)
  consortiumProviders ConsortiumProvider[]
  invoices            Invoice[]
  receipts            Receipt[]
  lspServices         LspService[]

  @@index([clientId, cuit])
  @@index([clientId])
}

model ConsortiumProvider {
  id           String     @id @default(cuid())
  consortiumId String
  providerId   String
  createdAt    DateTime   @default(now())
  consortium   Consortium @relation(fields: [consortiumId], references: [id], onDelete: Cascade)
  provider     Provider   @relation(fields: [providerId], references: [id], onDelete: Cascade)

  @@unique([consortiumId, providerId])
}

model Period {
  id            String       @id @default(cuid())
  clientId      String
  consortiumId  String
  year          Int
  month         Int
  status        PeriodStatus @default(ACTIVE)
  driveFolderId String?
  closedAt      DateTime?
  createdAt     DateTime     @default(now())
  updatedAt     DateTime     @updatedAt
  client        Client       @relation(fields: [clientId], references: [id], onDelete: Cascade)
  consortium    Consortium   @relation(fields: [consortiumId], references: [id], onDelete: Cascade)
  invoices      Invoice[]
  receipts      Receipt[]

  @@unique([consortiumId, year, month])
  @@index([consortiumId, status])
}

model LspService {
  id            String     @id @default(cuid())
  clientId      String
  consortiumId  String
  provider      String
  providerId    String?
  clientNumber  String
  description   String?
  createdAt     DateTime   @default(now())
  updatedAt     DateTime   @updatedAt
  client        Client     @relation(fields: [clientId], references: [id], onDelete: Cascade)
  consortium    Consortium @relation(fields: [consortiumId], references: [id], onDelete: Cascade)
  providerRef   Provider?  @relation(fields: [providerId], references: [id], onDelete: SetNull)
  invoices      Invoice[]

  @@unique([consortiumId, provider, clientNumber])
  @@index([clientId, provider, clientNumber])
}
